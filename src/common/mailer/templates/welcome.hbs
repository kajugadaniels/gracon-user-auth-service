<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>Account Activated — ID Verification Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #ede9ff;
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    }
    .wrapper { padding: 48px 20px; }
    .card {
      max-width: 580px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(91,35,255,0.13), 0 1px 4px rgba(0,0,0,0.06);
    }
    .header {
      background-color: #5B23FF;
      padding: 44px 48px 40px;
      text-align: center;
    }
    .brand-label {
      font-size: 11px;
      font-weight: 600;
      color: rgba(255,255,255,0.52);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 22px;
    }
    .header h1 {
      color: #ffffff;
      font-size: 26px;
      font-weight: 700;
      margin: 18px 0 8px;
      letter-spacing: -0.4px;
    }
    .header-sub {
      color: rgba(255,255,255,0.70);
      font-size: 14px;
      margin: 0;
    }
    .body { padding: 44px 48px 40px; }
    .greeting {
      font-size: 18px;
      font-weight: 600;
      color: #16103a;
      margin: 0 0 14px;
    }
    .text {
      font-size: 15px;
      color: #5a5380;
      line-height: 1.75;
      margin: 0 0 32px;
    }
    .id-box {
      background: rgba(91,35,255,0.05);
      border: 1.5px solid rgba(91,35,255,0.20);
      border-radius: 14px;
      padding: 22px 26px;
      margin: 0 0 36px;
    }
    .id-label {
      font-size: 11px;
      font-weight: 700;
      color: #5B23FF;
      text-transform: uppercase;
      letter-spacing: 1.4px;
      margin: 0 0 10px;
    }
    .id-value {
      font-size: 28px;
      font-weight: 700;
      color: #16103a;
      letter-spacing: 5px;
      font-family: 'SF Mono', 'Fira Code', 'Menlo', 'Courier New', monospace;
      margin: 0 0 8px;
    }
    .id-note {
      font-size: 12px;
      color: #9590b0;
      margin: 0;
    }
    .divider {
      border: none;
      border-top: 1px solid #ede9ff;
      margin: 0 0 28px;
    }
    .footer {
      background: #f5f3ff;
      border-top: 1px solid #ede9ff;
      padding: 24px 48px;
      text-align: center;
    }
    .footer p {
      font-size: 12px;
      color: #9590b0;
      margin: 0 0 4px;
      line-height: 1.65;
    }
    .footer p:last-child { margin: 0; }
  </style>
</head>
<body>
  <!-- Preheader -->
  <div style="display:none;font-size:1px;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    Your account is now active. Here is your Platform ID — keep it safe.
  </div>

  <div class="wrapper">
    <div class="card">

      <!-- Header -->
      <div class="header">
        <p class="brand-label">ID Verification Platform</p>
        <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto;">
          <tr>
            <td width="72" height="72" align="center" valign="middle"
                style="width:72px;height:72px;background:rgba(255,255,255,0.15);border:1.5px solid rgba(255,255,255,0.28);border-radius:36px;">
              <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 2.5L4 7.5V15c0 7.5 11 12.5 11 12.5S26 22.5 26 15V7.5L15 2.5z"
                      fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M10 15l4 4 7-7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </td>
          </tr>
        </table>
        <h1>Account Activated</h1>
        <p class="header-sub">Your identity has been verified successfully</p>
      </div>

      <!-- Body -->
      <div class="body">
        <p class="greeting">Welcome, {{postNames}} {{surName}}!</p>
        <p class="text">
          Great news — your email has been verified and your account is now fully active.
          Your unique Platform ID is shown below. Store it somewhere safe, as you may
          need it to recover your account in the future.
        </p>

        <div class="id-box">
          <p class="id-label">Your Platform ID</p>
          <p class="id-value">{{platformId}}</p>
          <p class="id-note">Keep this confidential. Never share it with anyone.</p>
        </div>

        <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto 36px;">
          <tr>
            <td align="center"
                style="border-radius:10px;background-color:#5B23FF;box-shadow:0 4px 18px rgba(91,35,255,0.36);">
              <a href="{{loginUrl}}" target="_blank"
                 style="display:inline-block;padding:15px 48px;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;letter-spacing:0.2px;font-family:'DM Sans',-apple-system,sans-serif;border-radius:10px;">
                Access Your Account
              </a>
            </td>
          </tr>
        </table>

        <hr class="divider" />

        <p style="font-size:13px;color:#9590b0;text-align:center;margin:0;line-height:1.65;">
          If you did not create this account, please contact our support team immediately.
        </p>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>&copy; {{currentYear}} ID Verification Platform. All rights reserved.</p>
        <p>You received this email because an account was created with your email address.</p>
      </div>

    </div>
  </div>
</body>
</html>
