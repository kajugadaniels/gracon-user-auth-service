<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>Reset Your Password — ID Verification Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #ede9ff;
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    }
    .wrapper { padding: 48px 20px; }
    .card {
      max-width: 580px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(91,35,255,0.13), 0 1px 4px rgba(0,0,0,0.06);
    }
    .header {
      background-color: #5B23FF;
      padding: 44px 48px 40px;
      text-align: center;
    }
    .brand-label {
      font-size: 11px;
      font-weight: 600;
      color: rgba(255,255,255,0.52);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 22px;
    }
    .header h1 {
      color: #ffffff;
      font-size: 26px;
      font-weight: 700;
      margin: 18px 0 8px;
      letter-spacing: -0.4px;
    }
    .header-sub {
      color: rgba(255,255,255,0.70);
      font-size: 14px;
      margin: 0;
    }
    .body { padding: 44px 48px 40px; }
    .greeting {
      font-size: 18px;
      font-weight: 600;
      color: #16103a;
      margin: 0 0 14px;
    }
    .text {
      font-size: 15px;
      color: #5a5380;
      line-height: 1.75;
      margin: 0 0 36px;
    }
    .expires {
      text-align: center;
      font-size: 13px;
      color: #9590b0;
      margin: 0 0 28px;
    }
    .warn-box {
      background: #fffbeb;
      border: 1.5px solid #fde68a;
      border-left: 4px solid #d97706;
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 13px;
      color: #78350f;
      line-height: 1.65;
      margin: 0 0 28px;
    }
    .warn-title {
      font-weight: 700;
      font-size: 13px;
      color: #92400e;
      margin: 0 0 4px;
    }
    .divider {
      border: none;
      border-top: 1px solid #ede9ff;
      margin: 0 0 24px;
    }
    .fallback {
      font-size: 12px;
      color: #9590b0;
      line-height: 1.7;
      word-break: break-all;
      margin: 0;
    }
    .fallback a { color: #5B23FF; text-decoration: none; }
    .footer {
      background: #f5f3ff;
      border-top: 1px solid #ede9ff;
      padding: 24px 48px;
      text-align: center;
    }
    .footer p {
      font-size: 12px;
      color: #9590b0;
      margin: 0 0 4px;
      line-height: 1.65;
    }
    .footer p:last-child { margin: 0; }
  </style>
</head>
<body>
  <!-- Preheader -->
  <div style="display:none;font-size:1px;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    We received a request to reset your password. Click below to choose a new one.
  </div>

  <div class="wrapper">
    <div class="card">

      <!-- Header -->
      <div class="header">
        <p class="brand-label">ID Verification Platform</p>
        <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto;">
          <tr>
            <td width="72" height="72" align="center" valign="middle"
                style="width:72px;height:72px;background:rgba(255,255,255,0.15);border:1.5px solid rgba(255,255,255,0.28);border-radius:36px;">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="13" width="18" height="12" rx="2.5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
                <path d="M9 13V9a5 5 0 0 1 10 0v4" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="14" cy="19" r="1.5" fill="white"/>
                <path d="M14 20.5v1.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </td>
          </tr>
        </table>
        <h1>Reset Your Password</h1>
        <p class="header-sub">Secure account access request</p>
      </div>

      <!-- Body -->
      <div class="body">
        <p class="greeting">Hello, {{postNames}} {{surName}}</p>
        <p class="text">
          We received a request to reset the password for your account. Click the
          button below to choose a new password. If you did not make this request,
          you can safely ignore this email — your password will remain unchanged.
        </p>

        <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto 20px;">
          <tr>
            <td align="center"
                style="border-radius:10px;background-color:#5B23FF;box-shadow:0 4px 18px rgba(91,35,255,0.36);">
              <a href="{{resetUrl}}" target="_blank"
                 style="display:inline-block;padding:15px 48px;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;letter-spacing:0.2px;font-family:'DM Sans',-apple-system,sans-serif;border-radius:10px;">
                Reset My Password
              </a>
            </td>
          </tr>
        </table>

        <p class="expires">This link will expire in <strong>{{expiresIn}}</strong>.</p>

        <div class="warn-box">
          <p class="warn-title">Security Notice</p>
          Never share this link with anyone. Our team will never ask you for it.
          If you did not request a password reset, please secure your account immediately.
        </div>

        <hr class="divider" />

        <p class="fallback">
          Button not working? Copy and paste this link into your browser:<br/>
          <a href="{{resetUrl}}">{{resetUrl}}</a>
        </p>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>&copy; {{currentYear}} ID Verification Platform. All rights reserved.</p>
        <p>If you did not request a password reset, please contact our support team.</p>
      </div>

    </div>
  </div>
</body>
</html>
