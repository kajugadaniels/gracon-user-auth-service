// Prisma schema — defines all database tables and relationships
// Run `npx prisma migrate dev` to apply changes to Neon Postgres
// Run `npx prisma generate` to regenerate the TypeScript client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phoneNumber  String?
  passwordHash String
  imageUrl     String?
  isVerified   Boolean   @default(false)  // true after email confirmation
  isActive     Boolean   @default(false)  // true after email confirmation
  isIdVerified Boolean   @default(false)  // true after face + document check passes
  idVerifiedAt DateTime?                  // timestamp when ID verification passed
  verificationAttempts Int @default(0)    // total attempts made — resets on success
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  citizenIdentity        CitizenIdentity?
  platformId             PlatformId?
  emailVerificationToken EmailVerificationToken?
  idVerifications        IdVerification[]        // one user can have many attempts

  @@map("users")
}

// ─── Citizen Identities ───────────────────────────────────────────────────────
model CitizenIdentity {
  id             String   @id @default(uuid())
  userId         String   @unique
  nidEncrypted   String                    // AES-256-CBC encrypted NID
  nidHash        String   @unique          // SHA-256 hash — for duplicate checks
  surName        String
  postNames      String
  sex            String
  dateOfBirth    DateTime
  countryOfBirth String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("citizen_identities")
}

// ─── Platform IDs ─────────────────────────────────────────────────────────────
model PlatformId {
  id           String   @id @default(uuid())
  userId       String   @unique
  pidEncrypted String                      // AES-256-CBC encrypted PID
  pidHash      String   @unique            // SHA-256 hash — for lookup and uniqueness
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_ids")
}

// ─── Email Verification Tokens ────────────────────────────────────────────────
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  tokenHash String                         // SHA-256 hash of raw token
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─── ID Verifications ─────────────────────────────────────────────────────────
// Audit log of every verification attempt — pass or fail
// Stores scores only — never images or biometric data
model IdVerification {
  id              String   @id @default(uuid())
  userId          String                        // which user attempted
  attemptNumber   Int                           // 1, 2, or 3 — max 3 per window
  documentMatch   Boolean                       // did typed NID match stored NID
  faceScore       Float                         // Rekognition CompareFaces 0-100
  livenessScore   Float                         // Rekognition FaceLiveness 0-100
  compositeScore  Float                         // weighted final score 0-100
  passed          Boolean                       // compositeScore >= 80 AND documentMatch
  failReason      String?                       // human-readable reason if failed
  ipAddress       String?                       // for fraud detection
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Index on userId + createdAt for fast attempt window queries
  @@index([userId, createdAt])
  @@map("id_verifications")
}