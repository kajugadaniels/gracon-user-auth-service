# auth environment - managed by secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3000
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
# Database role: gracon_auth_app
# Generate this role password with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Deployment secret source: AUTH_DATABASE_URL
DATABASE_URL=postgresql://gracon_auth_app:q8T3CVTmz0Xoh1mateNOTI00P0XmM5gH@host/dbname?sslmode=require

# User JWT
# Deployment secret source: PLATFORM_USER_JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Identity encryption
# Deployment secret source: PLATFORM_IDENTITY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=

# Citizen API
CITIZEN_API_URL=
CITIZEN_API_USERNAME=
# Deployment secret source: AUTH_CITIZEN_API_PASSWORD
CITIZEN_API_PASSWORD=

# Foreign identity service
# Deployment secret source: FOREIGN_IDENTITY_BRIDGE_URL
FOREIGN_IDENTITY_SERVICE_URL=http://localhost:3006/api/v1
# Deployment secret source: FOREIGN_IDENTITY_BRIDGE_USERNAME
FOREIGN_IDENTITY_SERVICE_USERNAME=service.foreign-identity@yourplatform.com
# Deployment secret source: FOREIGN_IDENTITY_BRIDGE_PASSWORD
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
FOREIGN_IDENTITY_SERVICE_PASSWORD=

# Mailer
# Deployment secret source: PLATFORM_SMTP_HOST
MAIL_HOST=
# Deployment secret source: PLATFORM_SMTP_PORT
MAIL_PORT=587
# Deployment secret source: PLATFORM_SMTP_USER
MAIL_USER=
# Deployment secret source: PLATFORM_SMTP_PASS
MAIL_PASS=
MAIL_FROM=

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4001,http://localhost:4002

# AWS S3
# Deployment secret source: PLATFORM_AWS_REGION
AWS_REGION=us-east-1
# Deployment secret source: PLATFORM_AWS_ACCESS_KEY_ID
AWS_ACCESS_KEY_ID=
# Deployment secret source: PLATFORM_AWS_SECRET_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=
# Deployment secret source: PLATFORM_AWS_S3_BUCKET_NAME
AWS_S3_BUCKET_NAME=

# Verification engine
ENGINE_URL=http://localhost:8000
# Deployment secret source: AUTH_ENGINE_API_KEY
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENGINE_API_KEY=

# Identity verification policy
VERIFICATION_ATTEMPT_WINDOW_HOURS=24

# Swagger docs basic auth
DOCS_BASIC_AUTH_USER=
# Deployment secret source: AUTH_DOCS_BASIC_AUTH_PASS
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DOCS_BASIC_AUTH_PASS=

# Fake verified user seed
# Development/test only. Database-owned SUPER_ADMIN seed variables live in api/database.
ALLOW_FAKE_VERIFIED_USERS_SEED=false
ALLOW_PRODUCTION_FAKE_VERIFIED_USERS_SEED=false
