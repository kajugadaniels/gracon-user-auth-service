# auth .env.example - managed by Milestone 10 secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3000
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
DATABASE_URL=

# User JWT
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Identity encryption
# Generate ENCRYPTION_SECRET with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=

# Citizen API
CITIZEN_API_URL=
CITIZEN_API_USERNAME=
CITIZEN_API_PASSWORD=

# Foreign identity service
# Generate FOREIGN_IDENTITY_SERVICE_PASSWORD with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
FOREIGN_IDENTITY_SERVICE_URL=http://localhost:3006/api/v1
FOREIGN_IDENTITY_SERVICE_USERNAME=service.foreign-identity@yourplatform.com
FOREIGN_IDENTITY_SERVICE_PASSWORD=

# Mailer
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Frontend and CORS
FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:4001,http://localhost:4002

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Verification engine
# Generate ENGINE_API_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=

# Identity verification policy
VERIFICATION_ATTEMPT_WINDOW_HOURS=24

# Swagger docs basic auth
# Generate DOCS_BASIC_AUTH_PASS with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DOCS_BASIC_AUTH_USER=
DOCS_BASIC_AUTH_PASS=

# Fake verified user seed
# Development/test only. Database-owned SUPER_ADMIN seed variables live in api/database.
ALLOW_FAKE_VERIFIED_USERS_SEED=false
ALLOW_PRODUCTION_FAKE_VERIFIED_USERS_SEED=false
