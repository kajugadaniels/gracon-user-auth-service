# ─── App ───────────────────────────────────────────────
APP_PORT=
APP_ENV=development

# ─── Neon Postgres ─────────────────────────────────────
DATABASE_URL=

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=

# ─── Encryption (AES-256 needs exactly 32 chars) ───────
ENCRYPTION_SECRET=

# ─── Citizen API (National ID lookup) ──────────────────
CITIZEN_API_URL=
CITIZEN_API_USERNAME=
CITIZEN_API_PASSWORD=

# ─── Mailer ────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── Frontend URL (for email verification links) ───────
FRONTEND_URL=http://localhost:4000

# ─── AWS (used for both Rekognition and S3) ──────────
AWS_REGION=u
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# ─── FastAPI Engine ────────────────────────────────────────────────────────
ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=same_key_as_in_engine_env_file