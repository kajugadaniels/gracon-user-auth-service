# ─── App ───────────────────────────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development          # development | production  (disables Swagger in production)

# ─── Database (Neon Postgres) ───────────────────────────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
# Runtime connection only. api/database owns migrations and Prisma generation.
DATABASE_URL=

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=

# ─── Encryption (AES-256-CBC) ───────────────────────────────────────────────────
# Must be EXACTLY 32 characters — no more, no less
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=

# ─── Citizen API (National ID lookup) ──────────────────────────────────────────
CITIZEN_API_URL=
CITIZEN_API_USERNAME=
CITIZEN_API_PASSWORD=

# ─── Foreign Identity Service (FIN lookup) ─────────────────────────────────────
# Default development URL for api/foreign-identity
# NIDA-style Basic Auth credentials for internal auth -> foreign-identity
# service-to-service calls. Use a dedicated service admin account email as the
# username so foreign-identity can still resolve a real admin for audit logs.
FOREIGN_IDENTITY_SERVICE_URL=http://localhost:3006/api/v1
FOREIGN_IDENTITY_SERVICE_USERNAME=service.foreign-identity@yourplatform.com
FOREIGN_IDENTITY_SERVICE_PASSWORD=your_foreign_identity_service_password

# ─── Mailer (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── Frontend URL ───────────────────────────────────────────────────────────────
# Optional additional allowed CORS origins, comma-separated.
# The admin app and documents app proxy session-recovery calls through here.
FRONTEND_URLS=http://localhost:4001,http://localhost:4002

# ─── AWS (S3 + Rekognition) ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# ─── FastAPI Verification Engine ────────────────────────────────────────────────
# In Docker: use the service name, e.g. http://engine:8000
# In development: http://localhost:8000
ENGINE_URL=http://localhost:8000
# Must match ENGINE_API_KEY in the engine .env
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENGINE_API_KEY=

# ─── Identity Verification Attempts ───────────────────────────────────────────
# Business lockout window for ID + face verification attempts.
# Default is 24 hours. Set to 0 in local/controlled test environments to
# disable this business lockout and allow repeated verification attempts.
VERIFICATION_ATTEMPT_WINDOW_HOURS=24

# ─── Swagger Docs Access (production only) ─────────────────────
# Basic auth credentials for /docs and /redoc in production.
# Leave empty in development — docs are open on localhost.
# Use a strong random password in production.
DOCS_BASIC_AUTH_USER=your_docs_admin_username
DOCS_BASIC_AUTH_PASS=your_strong_docs_password

# ─── Fake Verified User Seed (development/test only) ───────────────────────
# Enables prisma/seed-verified-users.ts. Keep false unless you intentionally
# need login-ready fake Rwandan users in a local or controlled test database.
# ALLOW_FAKE_VERIFIED_USERS_SEED=true npx ts-node -r dotenv/config prisma/seed-verified-users.ts
ALLOW_FAKE_VERIFIED_USERS_SEED=false
# Extra production guard. Do not enable unless this is an approved disposable
# production-like test environment, never the real production user database.
ALLOW_PRODUCTION_FAKE_VERIFIED_USERS_SEED=false
